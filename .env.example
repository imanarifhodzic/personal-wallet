# Copy to .env for local development. On Render, set these in the dashboard
# (Environment tab) instead of committing them.

# Local API port. Render provides PORT automatically, so leave this unset there.
PORT=3000

# Long random string used to sign JWTs.
JWT_SECRET=change-me-to-a-long-random-string

# Hosted libSQL/Turso database. Leave BOTH unset locally to use a local SQLite
# file (database/db.js falls back to file:local.db automatically).
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Email is sent via Resend's HTTP API (https://resend.com), because managed hosts
# like Render's free tier block outbound SMTP. Create a free Resend account and
# paste an API key here. On Render, set this in the Environment tab instead.
RESEND_API_KEY=re_your_resend_api_key
# Optional. Defaults to Resend's shared testing sender (onboarding@resend.dev),
# which can only deliver to your own Resend account email. To email any parent
# address, verify a domain in Resend and set this to an address on it.
EMAIL_FROM=Personal Wallet <onboarding@resend.dev>
